{
  "name": "bead-onboarding-form-validation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/signer-smoke.spec.ts --project=chromium",
    "test:discovery": "playwright test tests/signer-discovery.spec.ts --project=chromium",
    "test:discovery:physical-address": "powershell -NoProfile -Command \"$env:SAFE_DISCOVERY_EXPAND_PHYSICAL_ADDRESS='1'; npm run test:discovery; $code=$LASTEXITCODE; Remove-Item Env:SAFE_DISCOVERY_EXPAND_PHYSICAL_ADDRESS -ErrorAction SilentlyContinue; exit $code\"",
    "test:interactive": "playwright test tests/signer-interactive-validation.spec.ts --project=chromium",
    "test:units": "playwright test tests/bootstrap-units.spec.ts --project=chromium",
    "test:destructive": "powershell -NoProfile -Command \"$env:DESTRUCTIVE_VALIDATION='1'; npx playwright test tests/signer-discovery.spec.ts --project=chromium; Remove-Item Env:DESTRUCTIVE_VALIDATION\"",
    "bootstrap:gmail-auth": "tsx scripts/gmail-auth.ts",
    "bootstrap:live": "tsx scripts/bootstrap-live-run.ts",
    "bootstrap:live:physical-address": "powershell -NoProfile -Command \"$env:SAFE_DISCOVERY_EXPAND_PHYSICAL_ADDRESS='1'; npm run bootstrap:live; $code=$LASTEXITCODE; Remove-Item Env:SAFE_DISCOVERY_EXPAND_PHYSICAL_ADDRESS -ErrorAction SilentlyContinue; exit $code\"",
    "bootstrap:interactive": "tsx scripts/bootstrap-interactive-run.ts",
    "report:open": "playwright show-report artifacts/playwright-html-report",
    "summary:open": "powershell -NoProfile -Command \"Get-Content artifacts/latest-validation-summary.md\"",
    "reports:refresh": "npx tsx scripts/generate-mapping-calibration.ts && npm run scorecard:generate && npm run findings:generate",
    "reports:open": "npm run findings:open",
    "scorecard:generate": "tsx scripts/generate-scorecard.ts",
    "scorecard:open": "node -e \"process.stdout.write(require('fs').readFileSync('artifacts/latest-validation-scorecard.md', 'utf8'))\"",
    "findings:generate": "tsx scripts/generate-validation-findings.ts",
    "findings:open": "node -e \"process.stdout.write(require('fs').readFileSync('artifacts/latest-validation-findings.md', 'utf8'))\"",
    "align:sample": "tsx scripts/align-sample.ts",
    "align:sample:open": "powershell -NoProfile -Command \"Get-Content artifacts/sample-field-alignment.md\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marccastrechini/bead-onboarding-form-validation.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/marccastrechini/bead-onboarding-form-validation/issues"
  },
  "homepage": "https://github.com/marccastrechini/bead-onboarding-form-validation#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "googleapis": "^144.0.0",
    "tsx": "^4.19.2"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5"
  }
}
