# Signer URL (live, single-use) – the live bootstrap flow injects this
# automatically into the Playwright child process, so you do NOT need to
# paste one here when using `npm run bootstrap:live`.
DOCUSIGN_SIGNING_URL=

# ---------------------------------------------------------------------------
# Bead onboarding resend/resubmit endpoint
# ---------------------------------------------------------------------------
# Host/path/auth header are fully configurable because the public docs and
# the uploaded OpenAPI spec disagree on the exact shape of this endpoint.
BEAD_API_BASE_URL=https://api.bead.example.com
BEAD_ONBOARDING_RESEND_PATH=/v1/onboarding/applications/{applicationId}/resend
BEAD_AUTH_HEADER_NAME=Authorization
BEAD_AUTH_HEADER_VALUE=Bearer REPLACE_ME
BEAD_APPLICATION_ID=REPLACE_ME

# ---------------------------------------------------------------------------
# Gmail polling
# ---------------------------------------------------------------------------
BEAD_GMAIL_ADDRESS=you@example.com
# Local-only OAuth files – keep both OUT of git
GMAIL_CREDENTIALS_PATH=./.secrets/gmail-credentials.json
GMAIL_TOKEN_PATH=./.secrets/gmail-token.json
GMAIL_QUERY_FROM=dse@docusign.net
GMAIL_QUERY_SUBJECT_CONTAINS=Please DocuSign
GMAIL_POLL_TIMEOUT_MS=180000
GMAIL_POLL_INTERVAL_MS=5000
